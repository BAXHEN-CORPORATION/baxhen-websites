# ── Database ────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase Pooler recommended for serverless)
DATABASE_URL=postgresql://127.0.0.1:5432/baxhen

# ── Payload CMS ────────────────────────────────────────────────────
# Secret used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# ── Supabase Storage (S3-compatible) ───────────────────────────────
S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_KEY
S3_BUCKET=baxhen
S3_PRIVATE_BUCKET=baxhen-private
S3_PUBLIC_BASE_URL=https://your-project.supabase.co/storage/v1/object/public

# ── Public (NEXT_PUBLIC_* — safe for client) ──────────────────────
# Server URL for CORS, link generation, etc. No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Baxhen Platform ────────────────────────────────────────────────
# Comma-separated list of platform hostnames (must not be rewritten to client sites)
BAXHEN_PLATFORM_HOSTS=localhost:3000

# Preview domain prefix for client sites (e.g. preview.baxhen.pt)
BAXHEN_PREVIEW_DOMAIN=

# Default locale and supported locales for the platform
BAXHEN_DEFAULT_LOCALE=pt
BAXHEN_SUPPORTED_LOCALES=pt,en

# ── Contact ────────────────────────────────────────────────────────
CONTACT_EMAIL=hello@baxhen.pt
CONTACT_WHATSAPP=+351
